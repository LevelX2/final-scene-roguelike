{
  "name": "final-scene",
  "version": "0.1.0-alpha.1",
  "description": "Fight Through a Dying Movieverse",
  "main": "src/main.mjs",
  "scripts": {
    "build": "node ./node_modules/esbuild/bin/esbuild src/main.mjs --bundle --format=iife --platform=browser --outfile=dist/game.bundle.js",
    "check:js": "node ./scripts/check-js.mjs",
    "check:memory": "node ./scripts/check-memory.mjs",
    "lint": "eslint .",
    "lint:strict": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "verify:quick": "npm run lint:strict && npm run check:js && npm run test:modules",
    "verify": "npm run verify:quick && npm run test:e2e",
    "start:app": "npm run build && node ./server.mjs --port 4173",
    "start:client": "node ./scripts/start-client.mjs",
    "start:test": "npm run build && set DUNGEON_ROGUE_TEST_MODE=1&& node ./server.mjs --port 4173",
    "report:studios": "npm run build && node ./scripts/studio-stats.mjs",
    "test:modules": "node --test ./tests/modules/*.test.mjs",
    "test:e2e": "npm run build && node ./node_modules/playwright/cli.js test"
  },
  "keywords": [],
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "http-server": "^14.1.1",
    "playwright": "^1.59.1"
  }
}
